<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.layout.VBox?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.TextField?>
<?import javafx.geometry.Insets?>

<VBox spacing="30.0" alignment="CENTER" xmlns="http://javafx.com/javafx/8.0.171" xmlns:fx="http://javafx.com/fxml/1" fx:controller="com.example.NewClientController" stylesheets="@fonts.css" >
   <children>
      <HBox spacing="30.0" alignment="CENTER" >
         <children>
            <VBox spacing="15.0" alignment="CENTER">
               <children>
                  <TextField fx:id="usernameField" promptText="exampleUser" styleClass="normaltext" />
                  <TextField fx:id="passwordField" promptText="Example01!" styleClass="normaltext" />
                  <TextField fx:id="nameField" promptText="John Smith" styleClass="normaltext" />
                  <TextField fx:id="emailField" promptText="example@example.com" styleClass="normaltext" />
               </children>
            </VBox>
            <VBox spacing="35.0" alignment="CENTER_LEFT" >
               <children>
                  <Label text="Choose a username." styleClass="normaltext" />
                  <Label text="Choose a password." styleClass="normaltext" />
                  <Label text="What's your name?" styleClass="normaltext" />
                  <Label text="How can we contact you?" styleClass="normaltext" />
               </children>
            </VBox>
         </children>
      </HBox>
      <Button fx:id="confirmButton" text="Create Account" onAction="#createIndividualClient" styleClass="continue-button" />
      <Button fx:id="backButton" text="Cancel" onAction="#cancel" styleClass="continue-button" />
   </children>
</VBox>