<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.layout.VBox?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.Button?>
<?import javafx.geometry.Insets?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.control.ComboBox?>
<?import javafx.collections.FXCollections?>
<?import javafx.scene.control.ListView?>
<?import java.lang.String?>

<VBox alignment="CENTER" spacing="20.0" xmlns="http://javafx.com/javafx/8.0.171" xmlns:fx="http://javafx.com/fxml/1" fx:controller="com.example.DashboardController" stylesheets="@fonts.css" maxWidth="2500" >
   <children>
      <HBox fx:id="ribbonBox" alignment="CENTER" spacing="50.0">
         <children>
            <Label fx:id="welcomeLabel" text="" styleClass="subheader" />
            <Button fx:id="logoutButton" text="Log Out" onAction="#logout" styleClass="action-button" />
         </children>
      </HBox>
      <HBox fx:id="contentBox" alignment="CENTER" spacing="30.0">
         <children>
            <VBox fx:id="accountCentreBox" alignment="CENTER_LEFT" spacing="15.0">
               <children>
                  <Label text="Account Centre" styleClass="normaltext" />
                  <ListView fx:id="accountsView" styleClass="normaltext" minHeight="750" minWidth="1000" />
                  <Label text="Open a New Account" styleClass="normaltext" />
                  <ComboBox fx:id="typeSelector" styleClass="action-button" >
                     <items>
                        <FXCollections fx:factory="observableArrayList">
                           <String fx:value="Chequeing" />
                           <String fx:value="Savings" />
                           <String fx:value="Investment" />
                        </FXCollections>
                     </items>
                  </ComboBox>
                  <Button fx:id="openAccountButton" text="Open" onAction="#openAccount" styleClass="action-button" />
                  <Label fx:id="monthlyFeeLabel" text="" styleClass="subtext" />
                  <Label text="(!) Please contact a bank associate to close an account." styleClass="subtext" />
               </children>
            </VBox>
            <VBox fx:id="transactionManagerBox" alignment="TOP_LEFT" spacing="15.0">
               <children>
                  <Label text="Manage This Account" styleClass="normaltext" />
                  <TextField fx:id="transferToField" promptText="Where? (accountID)" styleClass="normaltext" />
                  <TextField fx:id="amntField" promptText="How much?" styleClass="normaltext" />
                  <Button fx:id="transferButton" text="Transfer" onAction="#transfer" styleClass="action-button" />
                  <Button fx:id="depositButton" text="Deposit" onAction="#deposit" styleClass="action-button" />
                  <Button fx:id="withdrawButton" text="Withdraw" onAction="#withdraw" styleClass="action-button" />
               </children>
            </VBox>
            <VBox fx:id="transactionHistoryBox" alignment="TOP_LEFT" spacing="15.0">
               <children>
                  <Label text="Your Recent Transactions" styleClass="normaltext" />
                  <ListView fx:id="transactionsView" styleClass="normaltext" minWidth="1500" minHeight="750" />
               </children>
            </VBox>
         </children>
      </HBox>
   </children>
</VBox>