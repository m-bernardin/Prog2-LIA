<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.layout.VBox?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.TextField?>
<?import javafx.geometry.Insets?>
<?import javafx.scene.control.*?>
<?import javafx.collections.FXCollections?>
<?import java.lang.String?>

<VBox alignment="CENTER" spacing="20.0" xmlns="http://javafx.com/javafx/8.0.171" xmlns:fx="http://javafx.com/fxml/1" fx:controller="com.example.NewClientController">
   <children>
      <Label text="select type" />
      <ComboBox fx:id="typeSelector" >
         <items>
            <FXCollections fx:factory="observableArrayList">
               <String fx:value="Individual" />
               <String fx:value="Student" />
               <String fx:value="Corporate" />
               <String fx:value="Vip" />
            </FXCollections>
         </items>
      </ComboBox>
      <Button fx:id="confirmSelection" text="Confirm" onAction="#confirmSelection"/>
   </children>
   <padding>
      <Insets bottom="20.0" left="20.0" right="20.0" top="20.0" />
   </padding>
</VBox>
