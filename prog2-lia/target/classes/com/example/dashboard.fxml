<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.layout.VBox?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.Button?>
<?import javafx.geometry.Insets?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.HBox?>

<VBox alignment="CENTER" spacing="20.0" xmlns="http://javafx.com/javafx/8.0.171" xmlns:fx="http://javafx.com/fxml/1" fx:controller="com.example.DashboardController">
   <children>
      <HBox fx:id="ribbonBox" alignment="CENTER" spacing="50.0">
         <children>
            <Label text="Welcome, %name%" />
            <Button fx:id="logoutButton" text="Log Out" onAction="#logout" />
         </children>
      </HBox>
      <HBox fx:id="contentBox" alignment="CENTER" spacing="15.0">
         <children>
            <VBox fx:id="accountCentreBox" alignment="CENTER_LEFT" spacing="15.0">
               <children>
                  <Label text="Account Centre" />

               </children>
            </VBox>
            <VBox fx:id="transactionManagerBox" alignment="CENTER_LEFT" spacing="15.0">
               <children>
                  <Label text="Make a Transfer" />
               </children>
            </VBox>
            <VBox fx:id="transactionHistoryBox" alignment="CENTER_LEFT" spacing="15.0">
               <children>
                  <Label text="Your Recent Transactions" />
               </children>
            </VBox>
         </children>
      </HBox>
   </children>
</VBox>