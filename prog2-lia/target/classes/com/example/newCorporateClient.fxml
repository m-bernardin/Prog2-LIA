<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.layout.VBox?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.TextField?>
<?import javafx.geometry.Insets?>

<HBox spacing="20.0" alignment="CENTER" xmlns="http://javafx.com/javafx/8.0.171" xmlns:fx="http://javafx.com/fxml/1" fx:controller="com.example.NewClientController">
   <children>
      <VBox spacing="30.0" alignment="CENTER">
         <children>
            <Label text="Choose a username." />
            <Label text="Choose a password." />
            <Label text="What's your name?" />
            <Label text="How can we contact you?" />
         </children>
      </VBox>
      <VBox spacing="20.0" alignment="CENTER">
         <children>
            <TextField fx:id="usernameField" promptText="Username" />
            <TextField fx:id="passwordField" promptText="Password" />
            <TextField fx:id="nameField" promptText="Full Name" />
            <TextField fx:id="emailField" promptText="Email" />
            <Button fx:id="confirmButton" text="Create Account" onAction="#createIndividualClient" />
         </children>
      </VBox>
   </children>
</HBox>